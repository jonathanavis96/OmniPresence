{
  "manifest_version": 3,
  "name": "OmniPresence Browser Bridge",
  "version": "1.0.0",
  "description": "Reports your active browser domain/category to OmniPresence for Discord Rich Presence. Only sends exact titles for explicitly whitelisted domains.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:47831/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OmniPresence Browser Bridge"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
