#!/usr/bin/env bash
# graphify-build — full STRUCTURAL + SEMANTIC graph build for OmniPresence.
# Produces graphify-out/graph.json (+ report + viz). Requires the `graphify`
# CLI on PATH and an LLM backend key (GEMINI_API_KEY by default).
#
# Usage: scripts/graphify-build            # full semantic build
#        scripts/graphify-build --ast      # structural-only (no LLM, free)
set -euo pipefail
cd "$(dirname "$0")/.."

if ! command -v graphify >/dev/null 2>&1; then
  echo "graphify CLI not found on PATH." >&2
  echo "See tools/graphify/README.md for the placeholder integration + install notes." >&2
  exit 127
fi

if [[ "${1:-}" == "--ast" ]]; then
  echo "[graphify-build] structural-only update (AST, no LLM)..."
  graphify update . --force
  exit 0
fi

# Pull the Gemini key from the shell profile if not already exported.
if [[ -z "${GEMINI_API_KEY:-}" ]] && grep -q GEMINI_API_KEY "$HOME/.bashrc" 2>/dev/null; then
  # shellcheck disable=SC1090
  GEMINI_API_KEY="$(grep -m1 GEMINI_API_KEY "$HOME/.bashrc" | sed -E 's/.*GEMINI_API_KEY=//; s/^["'"'"']//; s/["'"'"']$//')"
  export GEMINI_API_KEY
fi

echo "[graphify-build] semantic extraction (AST + LLM)..."
graphify extract . --backend gemini

echo "[graphify-build] relabelling communities with real names..."
GRAPHIFY_GEMINI_MODEL=gemini-3.1-flash-lite graphify label . || \
  echo "[graphify-build] label pass skipped/failed (non-fatal) — community placeholders kept."

echo "[graphify-build] done -> graphify-out/graph.json"
